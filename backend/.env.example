# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Database
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:pharmaerpo@1234@db.vkykyjnceobchyjiknhw.supabase.co:5432/postgres
# Redis
# Optional - defaults to localhost:6379 if not provided
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-secret-key-min-32-chars-long-for-security
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_TEMP_DIR=./tmp/uploads

# Alerts
EXPIRY_WARN_DAYS_1=30
EXPIRY_WARN_DAYS_2=60
EXPIRY_WARN_DAYS_3=90

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# External Integrations (Optional)
# ERP_WEBHOOK_SECRET=your-webhook-secret
# PRESCRIPTION_API_URL=https://prescription-api.example.com
# PRESCRIPTION_API_KEY=your-api-key

# Logging
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
